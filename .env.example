# ── 必填（Phase 0 對話最小可行版）────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token

# ── 本地模型（Ollama）────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
CHAT_MODEL=qwen3:14b        # 12GB 顯存退路：qwen3:8b
UTILITY_MODEL=qwen3:8b      # 背景呼叫（heartbeat / memory / browse…）
EMBEDDING_MODEL=bge-m3

# ── 資料庫 ───────────────────────────────────────────────────
DATABASE_PATH=./data/kana.db

# ── 選填：混合方案保留（Phase 5 或 chat 切回雲端時才需要）─────
ANTHROPIC_API_KEY=

# ── 選填：Threads 發文 ───────────────────────────────────────
THREADS_ACCESS_TOKEN=
THREADS_USER_ID=

# ── 選填：管理員審核頻道 ─────────────────────────────────────
ADMIN_CHANNEL_ID=
OWNER_USER_ID=

# ── 選填：YouTube（audio 功能，Phase 0 不用）─────────────────
YOUTUBE_API_KEY=
